PORT=5179
FRONTEND_ORIGIN=http://127.0.0.1:5500

# 공공데이터포털 일반인증키(Decoding). 예: AbCd...==
DATA_GO_KR_SERVICE_KEY=

# 실데이터 연동용(각 지자체 API URL). 데이터셋마다 경로가 다를 수 있어 분리합니다.
# 아래 3개는 "대여소 기본정보 / 재고현황 / 대여반납현황"에 해당합니다.
API_STATIONS_URL=
API_STOCK_URL=
API_USAGE_URL=

# 지역별로 엔드포인트가 다르면 backend/apiMap.json을 만들어 관리하세요.
# 형식은 backend/apiMap.example.json 참고.

# 대여/반납 현황정보 날짜 파라미터 이름(데이터셋 문서에 따라 다를 수 있음)
USAGE_START_PARAM=fromCrtrYmd
USAGE_END_PARAM=toCrtrYmd

# 개발 편의: true면 backend/src/mocks/*.json 사용
USE_MOCK=true

